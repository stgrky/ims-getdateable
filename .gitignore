# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# sanity
.sanity/
# Sanity Studio production build output (`npx sanity build` / `npx sanity deploy`)
/dist
# Per-deploy build directory left behind by the Sanity CLI
/sample-therapist
/ims-getdateable

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
